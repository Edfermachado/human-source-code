---
// src/pages/tags/index.astro
import TerminalLayout from "../../layouts/TerminalLayout.astro";
import { getCollection } from "astro:content";
import { slugify } from "../../utils/slugify"; // <-- Las importaciones siempre van al principio

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const allLogs = await getCollection("log");

// 1. Filtramos los sectores válidos
const validLogs = allLogs.filter(
  (log) => log.data && log.data.date && !log.data.draft,
);

// 2. Extraemos las etiquetas únicas y las ordenamos alfabéticamente
const uniqueTags = [
  ...new Set(validLogs.flatMap((log) => log.data.tags || [])),
].sort();
---

<TerminalLayout title="~/taxonomia - ◯ >_">
  <section class="tags-directory">
    <h1>~/taxonomia</h1>
    <p class="directory-description">
      Índice del sistema de archivos conceptual. Selecciona un nodo para filtrar
      el registro.
    </p>

   <div class="tags-grid">
      {
        uniqueTags.map((tag) => {
          // 1. Calculamos los commits
          const count = validLogs.filter((log) =>
            log.data.tags?.includes(tag),
          ).length;

          // 2. Ejecutamos el formateador ANTES de tocar el HTML
          const tagSlug = slugify(tag);

          // 3. Inyectamos la variable ya limpia
          return (
            <a href={`${base}/tags/${tagSlug}`} class="tag-card">
              <span class="tag-name">
                <span class="prefix">::</span>
                {tag}
              </span>
              <span class="tag-count">
                [{count} commit{count !== 1 ? "s" : ""}]
              </span>
            </a>
          );
        })
      }
    </div>
  </section>
</TerminalLayout>

<style>
  .tags-directory h1 {
    color: var(--color-ceniza);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    font-weight: normal;
    font-family: var(--font-mono);
  }

  .directory-description {
    color: var(--color-comentario);
    font-style: italic;
    margin-bottom: 3rem;
    font-size: 0.9rem;
  }

  .tags-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .tag-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    background-color: var(--color-superficie);
    border: 1px solid transparent;
    border-left: 2px solid var(--color-comentario);
    text-decoration: none;
    font-family: var(--font-mono);
    transition: all 0.2s ease;
  }

  .tag-card:hover {
    border-left-color: var(--color-liquen);
    background-color: var(--color-vacuo);
    border-top: 1px solid var(--color-superficie);
    border-right: 1px solid var(--color-superficie);
    border-bottom: 1px solid var(--color-superficie);
  }

  .tag-name {
    color: var(--color-ceniza);
  }

  .prefix {
    color: var(--color-liquen);
    opacity: 0.7;
  }

  .tag-card:hover .tag-name {
    color: var(--color-liquen);
  }

  .tag-count {
    color: var(--color-comentario);
    font-size: 0.85rem;
  }
</style>
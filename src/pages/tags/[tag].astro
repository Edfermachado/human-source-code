---
// src/pages/tags/[tag].astro
import TerminalLayout from "../../layouts/TerminalLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { slugify } from "../../utils/slugify"; // 1. Importamos la herramienta

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

export async function getStaticPaths() {
  const allLogs = await getCollection("log");

  const validLogs = allLogs.filter(
    (log) => log.data && log.data.date && !log.data.draft,
  );

  const uniqueTags = [
    ...new Set(validLogs.flatMap((log) => log.data.tags || [])),
  ];

  return uniqueTags.map((tag) => {
    const filteredLogs = validLogs.filter((log) =>
      log.data.tags?.includes(tag),
    );
    const sortedLogs = filteredLogs.sort(
      (a, b) => b.data.date!.valueOf() - a.data.date!.valueOf(),
    );

    return {
      // 2. La URL del navegador usará la versión esterilizada (ej: dinamicas-de-poder)
      params: { tag: slugify(tag) },
      // 3. Pasamos el tag original sin alterar para la interfaz visual
      props: { logs: sortedLogs, originalTag: tag },
    };
  });
}

interface Props {
  logs: CollectionEntry<"log">[];
  originalTag: string;
}

const { tag } = Astro.params;
const { logs, originalTag } = Astro.props;
---

<TerminalLayout title={`~/taxonomia/::${tag} - ◯ >_`}>
  <section class="log-archive">
    <h1>~/taxonomia/<span class="highlight">::{tag}</span></h1>
    <p class="directory-description">
      Registros filtrados bajo el concepto de [{originalTag}]. {logs.length} commit(s)
      encontrados.
    </p>

    <div class="commit-list">
      {
        logs.map((log) => {
          const dateStr = log.data.date!.toISOString().split("T")[0];

          return (
            <article class="commit-entry">
              <time datetime={log.data.date!.toISOString()} class="commit-date">
                [{dateStr}]
              </time>
              <a href={`${base}/log/${log.slug}`} class="commit-message">
                {log.data.title}
              </a>
              <div class="commit-tags">
                {log.data.tags?.map((t) => {
                  const cleanTag = slugify(t);
                  return (
                    <a href={`${base}/tags/${cleanTag}`} class="tag">
                      ::{t}
                    </a>
                  );
                })}
              </div>
            </article>
          );
        })
      }
    </div>
  </section>
</TerminalLayout>

<style>
  /* Reutilizamos la estructura del index de logs, adaptada para la taxonomía */
  .log-archive h1 {
    color: var(--color-ceniza);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    font-weight: normal;
    font-family: var(--font-mono);
  }

  .highlight {
    color: var(--color-liquen);
  }

  .directory-description {
    color: var(--color-comentario);
    font-style: italic;
    margin-bottom: 3rem;
    font-size: 0.9rem;
  }

  .commit-list {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .commit-entry {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    padding: 0.5rem 0;
    border-bottom: 1px dotted var(--color-superficie);
    transition: background-color 0.2s ease;
  }

  .commit-entry:hover {
    background-color: var(--color-superficie);
  }

  .commit-date {
    color: var(--color-comentario);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .commit-message {
    color: var(--color-ceniza);
    font-family: var(--font-mono);
    text-decoration: none;
    border-bottom: none;
  }

  .commit-message:hover {
    color: var(--color-liquen);
  }

  .commit-tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    color: var(--color-liquen);
    font-size: 0.8rem;
    opacity: 0.7;
    text-decoration: none;
    border-bottom: none;
  }

  .tag:hover {
    opacity: 1;
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .commit-entry {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      padding: 1rem 0; /* Aumentamos el área de toque del bloque */
    }
    .commit-message {
      font-size: 1.1rem;
      order: 1; /* Forzamos que el título aparezca primero */
    }
    .commit-date {
      order: 2; /* Fecha de segundo */
      opacity: 0.7;
    }
    .commit-tags {
      order: 3; /* Etiquetas de último */
      margin-top: 0.2rem;
    }
  }
</style>

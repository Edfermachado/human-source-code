---
// src/pages/log/index.astro
import TerminalLayout from '../layouts/TerminalLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
const base = import.meta.env.BASE_URL;

const allLogs = await getCollection('log');

// 1. Manejo histórico: Separamos los archivos recientes de los fragmentos antiguos sin metadatos
const publishedLogs: CollectionEntry<'log'>[] = [];
const recoveredLogs: CollectionEntry<'log'>[] = []; // Archivos antiguos sin fecha

allLogs.forEach(log => {
  if (!log.data?.draft) {
    if (log.data?.date) {
      publishedLogs.push(log);
    } else {
      recoveredLogs.push(log);
      // Aviso silencioso en la terminal de compilación
      console.info(`[RECOVERY] Metadatos de tiempo no encontrados. Asignando 'lost' a: ~/log/${log.slug || log.id}`);
    }
  }
});

// 2. Ordenamos secuencialmente solo los registros con fecha válida
publishedLogs.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<TerminalLayout title="~/log - ◯ >_">
  <section class="log-archive">
    <h1>~/log</h1>
    <p class="directory-description">
      Registro secuencial de disecciones. Repositorio principal del código fuente humano. Ordenado por timestamp de compilación.
    </p>

    <div class="commit-list">
      {publishedLogs.map((log) => {
        const dateStr = log.data.date ? log.data.date.toISOString().split('T')[0] : '';
        
        return (
          <article class="commit-entry">
            <time datetime={log.data.date?.toISOString()} class="commit-date">
              [{dateStr}]
            </time>
            <a href={`${base}/log/${log.slug}`} class="commit-message">
              {log.data.title}
            </a>
            <div class="commit-tags">
              {log.data.tags?.map(tag => (
                <span class="tag">::{tag.toLowerCase()}</span>
              ))}
            </div>
          </article>
        );
      })}
    </div>

    {/* Sección para los ensayos antiguos recuperados sin fecha */}
    {recoveredLogs.length > 0 && (
      <div class="system-recovery">
        <p class="warning-title">>> [INFO] Fragmentos recuperados de versiones anteriores de la mente:</p>
        <div class="commit-list">
          {recoveredLogs.map(log => (
            <article class="commit-entry">
              <time class="commit-date" title="Metadatos de tiempo perdidos">
                [timestamp: lost]
              </time>
              <a href={`${base}/log/${log.slug}`} class="commit-message">
                {log.data.title}
              </a>
              <div class="commit-tags">
                {log.data.tags?.map(tag => (
                  <span class="tag">::{tag.toLowerCase()}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    )}
  </section>
</TerminalLayout>

<style>
  .log-archive h1 {
    color: var(--color-ceniza);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    font-weight: normal;
  }
  
  .directory-description {
    color: var(--color-comentario);
    font-style: italic;
    margin-bottom: 3rem;
    font-size: 0.9rem;
  }

  .commit-list {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .commit-entry {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    padding: 0.5rem 0;
    border-bottom: 1px dotted var(--color-superficie);
    transition: background-color 0.2s ease;
  }src/pages/tags/index.astro

  .commit-entry:hover {
    background-color: var(--color-superficie);
  }

  .commit-date {
    color: var(--color-comentario);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .commit-message {
    color: var(--color-ceniza);
    font-family: var(--font-mono);
    text-decoration: none;
    border-bottom: none;
  }

  .commit-message:hover {
    color: var(--color-liquen);
  }

  .commit-tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    color: var(--color-liquen);
    font-size: 0.8rem;
    opacity: 0.7;
  }

  /* Estilos para el bloque de diagnóstico de errores */
  .system-warning {
    margin-top: 4rem;
    padding: 1rem;
    border-left: 2px solid #D08770; /* Un tono óxido sutil para alertas */
    background-color: var(--color-superficie);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-comentario);
  }

  .warning-title {
    color: #D08770;
    margin-bottom: 0.5rem;
  }

  .system-warning ul {
    list-style-type: none;
    padding-left: 1rem;
  }

  @media (max-width: 600px) {
    .commit-entry {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .commit-date, .commit-tags {
      font-size: 0.8rem;
    }
  }
</style>
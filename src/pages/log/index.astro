---
// src/pages/log/index.astro
import TerminalLayout from '../../layouts/TerminalLayout.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// 1. Consultar la colección completa de ensayos
const allLogs = await getCollection('log');

// 2. Filtrar borradores (si los hay) y ordenar cronológicamente (más reciente primero)
const publishedLogs = allLogs
  .filter(log => !log.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<TerminalLayout title="~/log - ◯ >_">
  <section class="log-archive">
    <h1>~/log</h1>
    <p class="directory-description">
      Registro secuencial de ensayos. Ordenado por fecha de commit.
    </p>

    <div class="commit-list">
      {publishedLogs.map((log) => {
        // Formatear fecha a YYYY-MM-DD
        const dateStr = log.data.date.toISOString().split('T')[0];
        
        return (
          <article class="commit-entry">
            <time datetime={log.data.date.toISOString()} class="commit-date">
              [{dateStr}]
            </time>
            <a href={`${base}log/${log.slug}`} class="commit-message">
              {log.data.title}
            </a>
            <div class="commit-tags">
              {log?.data.tags?.map(tag => (
                <span class="tag">::{tag.toLowerCase()}</span>
              ))}
            </div>
          </article>
        );
      })}
    </div>
  </section>
</TerminalLayout>

<style>
  .log-archive h1 {
    color: var(--color-ceniza);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    font-weight: normal;
  }
  
  .directory-description {
    color: var(--color-comentario);
    font-style: italic;
    margin-bottom: 3rem;
    font-size: 0.9rem;
  }

  .commit-list {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .commit-entry {
    display: grid;
    /* Grid que simula columnas de una terminal: Fecha | Título | Etiquetas */
    grid-template-columns: auto 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    padding: 0.5rem 0;
    border-bottom: 1px dotted var(--color-superficie);
    transition: background-color 0.2s ease;
  }

  .commit-entry:hover {
    background-color: var(--color-superficie);
  }

  .commit-date {
    color: var(--color-comentario);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .commit-message {
    color: var(--color-ceniza);
    font-family: var(--font-mono); /* Mantenemos el índice en monoespaciado */
    text-decoration: none;
    border-bottom: none;
  }

  .commit-message:hover {
    color: var(--color-liquen);
  }

  .commit-tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    color: var(--color-liquen);
    font-size: 0.8rem;
    opacity: 0.7;
  }
  
  /* Responsividad básica para pantallas pequeñas */
  @media (max-width: 600px) {
    .commit-entry {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .commit-date, .commit-tags {
      font-size: 0.8rem;
    }
  }
</style>
---
// src/pages/log/index.astro
import TerminalLayout from "../../layouts/TerminalLayout.astro";
import { getCollection } from "astro:content";
import { slugify } from "../../utils/slugify"; // Ya lo tenías importado, excelente

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// 1. Consultar la colección completa de ensayos
const allLogs = await getCollection("log");

// 2. Filtrar borradores y ordenar cronológicamente
const publishedLogs = allLogs
  .filter((log) => !log.data.draft)
  .sort((a, b) => {
    // Si la fecha existe, extraemos su valor; si es nula, le asignamos 0.
    const dateA = a.data.date ? a.data.date.valueOf() : 0;
    const dateB = b.data.date ? b.data.date.valueOf() : 0;

    // Orden descendente (del más nuevo al más viejo)
    return dateB - dateA;
  });
---

<TerminalLayout title="~/log - ◯ >_">
  <section class="log-archive">
    <h1>~/log</h1>
    <p class="directory-description">
      Registro secuencial de ensayos. Ordenado por fecha de commit.
    </p>

    <div class="commit-list">
      {
        publishedLogs.map((log) => {
          // Si hay fecha, la formatea; si no, escupe 'lost'
          const dateStr = log.data.date
            ? log.data.date.toISOString().split("T")[0]
            : "lost";

          // 3. Aislamos la limpieza del ID antes de inyectarla al HTML
          const rawName = log.id.replace(/\.(md|mdx)$/, "");
          const safeSlug = slugify(rawName);

          return (
            <article class="commit-entry">
              <time datetime={log.data.date?.toISOString()} class="commit-date">
                [{dateStr}]
              </time>
              <a href={`${base}/log/${safeSlug}`} class="commit-message">
                {log.data.title}
              </a>
              <div class="commit-tags">
                {log.data.tags?.map((tag) => (
                  <span class="tag">::{tag}</span>
                ))}
              </div>
            </article>
          );
        })
      }
    </div>
  </section>
</TerminalLayout>
<style>
  .log-archive h1 {
    color: var(--color-ceniza);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    font-weight: normal;
  }

  .directory-description {
    color: var(--color-comentario);
    font-style: italic;
    margin-bottom: 3rem;
    font-size: 0.9rem;
  }

  .commit-list {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .commit-entry {
    display: grid;
    /* Grid que simula columnas de una terminal: Fecha | Título | Etiquetas */
    grid-template-columns: auto 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    padding: 0.5rem 0;
    border-bottom: 1px dotted var(--color-superficie);
    transition: background-color 0.2s ease;
  }

  .commit-entry:hover {
    background-color: var(--color-superficie);
  }

  .commit-date {
    color: var(--color-comentario);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .commit-message {
    color: var(--color-ceniza);
    font-family: var(--font-mono); /* Mantenemos el índice en monoespaciado */
    text-decoration: none;
    border-bottom: none;
  }

  .commit-message:hover {
    color: var(--color-liquen);
  }

  .commit-tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    color: var(--color-liquen);
    font-size: 0.8rem;
    opacity: 0.7;
  }

  @media (max-width: 600px) {
    .commit-entry {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      padding: 1rem 0; /* Aumentamos el área de toque del bloque */
    }
    .commit-message {
      font-size: 1.1rem;
      order: 1; /* Forzamos que el título aparezca primero */
    }
    .commit-date {
      order: 2; /* Fecha de segundo */
      opacity: 0.7;
    }
    .commit-tags {
      order: 3; /* Etiquetas de último */
      margin-top: 0.2rem;
    }
  }
</style>

---
// src/pages/log/[slug].astro
import { getCollection, render } from 'astro:content';
import EssayLayout from '../../layouts/EssayLayout.astro';

export async function getStaticPaths() {
  const logEntries = await getCollection('log');
  
  return logEntries.map(entry => {
    // Estrategia directa: tomamos el ID físico y le quitamos la extensión
    const cleanSlug = entry.id.replace(/\.(md|mdx)$/, '');
    
    return {
      params: { slug: cleanSlug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
// Usamos el motor moderno de renderizado
const { Content } = await render(entry);
---

<EssayLayout frontmatter={entry.data} rawContent={entry.body}>
  <Content />
</EssayLayout>
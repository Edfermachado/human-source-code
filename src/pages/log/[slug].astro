---
// src/pages/log/[slug].astro
import { getCollection, render } from 'astro:content';
import EssayLayout from '../../layouts/EssayLayout.astro';

export async function getStaticPaths() {
  const logEntries = await getCollection('log');
  
  return logEntries.map(entry => ({
    // Usamos slug o id dependiendo de la versión interna de Astro
    params: { slug: entry.slug || entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
// Usamos el motor moderno de renderizado
const { Content } = await render(entry);
---

<EssayLayout frontmatter={entry.data} rawContent={entry.body}>
  <Content />
</EssayLayout>
---
// src/pages/log/[slug].astro
import { getCollection, render } from 'astro:content';
import EssayLayout from '../../layouts/EssayLayout.astro';
import { slugify } from '../../utils/slugify'; // 1. Importamos la herramienta

export async function getStaticPaths() {
  const logEntries = await getCollection('log');
  
  return logEntries.map(entry => {
    // 1. Extirpamos la extensión del archivo (.md o .mdx)
    const rawName = entry.id.replace(/\.(md|mdx)$/, '');
    
    return {
      // 2. Ahora sí esterilizamos el nombre limpio
      params: { slug: slugify(rawName) },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
// Usamos el motor moderno de renderizado
const { Content } = await render(entry);
---

<EssayLayout frontmatter={entry.data} rawContent={entry.body}>
  <Content />
</EssayLayout>